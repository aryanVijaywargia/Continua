FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy lockfile first for caching
COPY sdks/python/pyproject.toml sdks/python/uv.lock ./sdks/python/

# Install dependencies
WORKDIR /app/sdks/python
RUN uv sync --frozen

# Copy source and tests
COPY sdks/python/src ./src
COPY sdks/python/tests ./tests
COPY tests/integration/python ./integration

CMD ["uv", "run", "pytest", "integration/", "-v"]
