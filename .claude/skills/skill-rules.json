{
  "version": "1.0",
  "description": "Skill activation triggers for Continua. Controls when skills auto-inject based on prompt keywords/intent.",
  "skills": {
    "continua-backend-dev": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "skillPath": ".claude/skills/continua-backend-dev/SKILL.md",
      "promptTriggers": {
        "keywords": [
          "api", "endpoint", "handler", "router", "chi",
          "sqlc", "query", "migration", "postgres",
          "make generate", "openapi", "contract",
          "mapper", "server_gen", "fx", "cobra"
        ],
        "intentPatterns": [
          "(add|create|implement).*?(endpoint|handler|api|route)",
          "(add|create|run).*?migration",
          "(add|write).*?(sqlc|query|sql)"
        ]
      },
      "fileTriggers": {
        "paths": ["internal/api/**", "internal/store/**", "db/platform/**", "contracts/openapi/**", "cmd/continua/**"]
      }
    },
    "continua-integrations": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "skillPath": ".claude/skills/continua-integrations/SKILL.md",
      "promptTriggers": {
        "keywords": [
          "sdk", "python sdk", "typescript sdk", "proxy", "llm proxy",
          "langchain", "crewai", "instrumentation"
        ],
        "intentPatterns": [
          "(add|create|update).*?sdk",
          "(implement|build).*?proxy",
          "(add|create).*?(langchain|crewai)"
        ]
      },
      "fileTriggers": {
        "paths": ["sdks/**", "internal/proxy/**"]
      }
    },
    "continua-observability": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "skillPath": ".claude/skills/continua-observability/SKILL.md",
      "promptTriggers": {
        "keywords": [
          "trace", "span", "payload", "session",
          "websocket", "real-time", "streaming", "replay",
          "token count", "cost", "span tree"
        ],
        "intentPatterns": [
          "(add|create|implement).*?(trace|span|payload)",
          "(implement|add).*?websocket",
          "replay.*?(trace|session)"
        ]
      },
      "fileTriggers": {
        "paths": ["contracts/websocket/**", "internal/ws/**"]
      }
    },
    "continua-testing": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "skillPath": ".claude/skills/continua-testing/SKILL.md",
      "promptTriggers": {
        "keywords": [
          "test", "tests", "testing", "make test",
          "go test", "vitest", "pytest", "integration test"
        ],
        "intentPatterns": [
          "(add|write|create).*?test",
          "(run|execute).*?test"
        ]
      },
      "fileTriggers": {
        "paths": ["**/*_test.go", "**/*.test.ts"]
      }
    },
    "skill-developer": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "skillPath": ".claude/skills/skill-developer/SKILL.md",
      "promptTriggers": {
        "keywords": [
          "skill", "skills", "skill-rules", "hook", "hooks",
          "trigger", "skill activation", "SKILL.md"
        ],
        "intentPatterns": [
          "(create|add|modify).*?skill",
          "(debug|fix).*?skill"
        ]
      },
      "fileTriggers": {
        "paths": [".claude/skills/**", ".claude/hooks/**"]
      }
    }
  }
}
